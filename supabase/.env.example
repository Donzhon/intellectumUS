# Secrets for the Edge Functions (set via `supabase secrets set ...`
# or in the Supabase Dashboard -> Edge Functions -> Secrets).
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are provided automatically
# in the deployed runtime; you only need them for local development.

# --- Provided automatically when deployed (needed only locally) ---
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- CORS: comma-separated allowed origins, or * for any ---
ALLOWED_ORIGINS=https://www.intellectumus.com,https://intellectumus.com

# --- Admin panel shared password ---
ADMIN_PASSWORD=change-me-to-a-long-random-string

# --- Telegram bot notifications ---
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=your-numeric-chat-id

# --- Email notifications via Resend ---
RESEND_API_KEY=re_your_resend_api_key
NOTIFY_EMAIL_FROM=IntellectumUS <noreply@your-verified-domain.com>
NOTIFY_EMAIL_TO=admin@your-domain.com
